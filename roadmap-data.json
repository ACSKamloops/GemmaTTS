{
  "repo": "ACSKamloops/GemmaTTS",
  "project_title": "Generic Gemma + TTS Roadmap",
  "milestones": [
    [
      "M0 Requirements, Benchmarks & Risk Gates",
      "Define use cases, verify model/resource assumptions, and establish safety boundaries."
    ],
    [
      "M1 Core Inference Service",
      "Build the service shell, local LLM integration, request/job model, and response contracts."
    ],
    [
      "M2 TTS Pipeline",
      "Implement Kokoro primary TTS, Piper fallback, voice registry, normalization, encoding, and cache."
    ],
    [
      "M3 Audio Outputs & Transport",
      "Support file, HTTP, local speaker, PCM streaming, and generic client playback integrations."
    ],
    [
      "M4 App Adapters",
      "Create adapters for CLI, desktop apps, game/NPC systems, batch narration, and external APIs."
    ],
    [
      "M5 UI, Metrics & Observability",
      "Dashboard, job history, voice preview, latency/resource metrics, and logs."
    ],
    [
      "M6 Security, Abuse Resistance & Privacy",
      "Input/output safety, auth, rate limits, signed audio IDs, filesystem protections, and retention policy."
    ],
    [
      "M7 Packaging, Docs & Release",
      "Docker, setup guides, model download docs, cross-platform scripts, release process."
    ]
  ],
